#!/usr/bin/env sh

set -eu

# Make mise available in the current shell.
{{ template "mise-shellenv" . }}

if ! command -v mise >/dev/null; then
    >&2 echo "[dotfiles][upt] ERROR: 'mise' command not found, skipping package installation"
    exit 1
fi

echo "[dotfiles][upt] Installing Upt packages..."

mise run upt update
{{ range .packages.upt -}}
mise run upt -- install {{ . | quote }} --yes
{{ end -}}
{{ if eq .chezmoi.os "linux" -}}
{{   range .packages.upt_linux -}}
mise run upt -- install {{ . | quote }} --yes
{{   end -}}
{{ end -}}
